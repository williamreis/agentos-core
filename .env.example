# Autenticação nos POST /agent/* (false = não exige Authorization)
AUTH_ENABLED=false

# Chaves de API (MVP). Header: Authorization: Bearer <valor> ou só a chave
FRAUD_API_KEY=dev-fraud-key
FAQ_API_KEY=dev-faq-key

# Porta no host (máquina onde roda o Docker) → mapeada para o container
API_PORT=8081
UI_PORT=8082

# Portas ouvidas *dentro* do container (deve bater com uvicorn/streamlit)
API_CONTAINER_PORT=8000
UI_CONTAINER_PORT=8501

# RAG (FAISS): após `python -m scripts.ingest_rag`, a API usa o índice em data/
# RAG_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# RAG_MIN_SIMILARITY=0.28
# RAG_FORCE_KEYWORD=1  # força só busca por palavra (testes / debug)

# Agente fraud: classificação semântica opcional (embeddings; mesmo RAG_MODEL)
# FRAUD_SEMANTIC=false
# FRAUD_SEMANTIC_ENABLED=false
